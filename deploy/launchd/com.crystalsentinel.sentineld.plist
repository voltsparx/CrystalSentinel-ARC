<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.crystalsentinel.sentineld</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/sentineld</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>WorkingDirectory</key>
  <string>/usr/local/var/lib/crystalsentinel</string>
  <key>StandardOutPath</key>
  <string>/usr/local/var/log/crystalsentinel/sentineld.log</string>
  <key>StandardErrorPath</key>
  <string>/usr/local/var/log/crystalsentinel/sentineld.err.log</string>
</dict>
</plist>
